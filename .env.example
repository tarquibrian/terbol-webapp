# URL publica del sitio. Usada para metadata SEO/canonicals.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL base del CMS/API general usado por las secciones del sitio.
NEXT_PUBLIC_API_URL=https://cms.terbolinspira.com/api

# URL base de archivos del CMS.
NEXT_PUBLIC_STORAGE_URL=https://cms.terbolinspira.com/storage

# Secret obligatorio para POST /api/revalidate.
# Debe coincidir con el header x-revalidate-secret enviado por el CMS.
REVALIDATE_SECRET=replace-with-a-random-secret

# Endpoint server-side opcional para el catalogo de productos.
# Si queda vacio o no existe, la app usa el mock local.
# Puede ser absoluto o relativo a NEXT_PUBLIC_API_URL.
PRODUCTS_API_URL=

# Endpoint server-side opcional para detalle de producto.
# Acepta placeholders {id} o :id. Si queda vacio, se intenta usar
# PRODUCTS_API_URL/{id}; si tampoco existe, se usa el mock local.
PRODUCTS_DETAIL_API_URL=

# Token opcional para el API de productos. No se expone al cliente.
PRODUCTS_API_TOKEN=
