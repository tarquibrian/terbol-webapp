# URL publica del sitio. Usada para metadata SEO/canonicals.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL base del CMS/API general usado por las secciones del sitio.
NEXT_PUBLIC_API_URL=https://cms.terbolinspira.com/api

# URL base de archivos del CMS.
NEXT_PUBLIC_STORAGE_URL=https://cms.terbolinspira.com/storage

# ─── SMTP para el formulario de contacto (/about) ──────────────────────────────
# Si NO se definen estas variables, POST /api/contact responde 500 controlado
# ("Envío no configurado") y el formulario muestra un error. La app no crashea.
# Para activar el envío basta con rellenar estas 7 variables y reiniciar.
#
# Host del servidor SMTP del proveedor de correo (Google Workspace, hosting, etc.)
#   Google Workspace/Gmail -> smtp.gmail.com
SMTP_HOST=
# Puerto: 587 = STARTTLS (recomendado) | 465 = SSL
SMTP_PORT=587
# true solo si usas el puerto 465 (SSL). Para 587 dejar en false.
SMTP_SECURE=false
# Usuario/buzón autenticado del SMTP.
SMTP_USER=
# Contraseña del buzón. En Gmail/Workspace usar un App Password (requiere 2FA).
SMTP_PASS=
# Bandeja de destino donde llegan los mensajes del formulario.
CONTACT_TO=
# Remitente que aparece en el email. Debe pertenecer al dominio autenticado.
#   Ejemplo: "Web Terbol <no-reply@terbol.com.bo>"
CONTACT_FROM=
